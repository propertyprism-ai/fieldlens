        "jina_fallback": "https://r.jina.ai/https://mcassessor.maricopa.gov",
        "notes": "搜索时用街道地址即可（如 '21145 E Saddle Way'），不用写城市"
      },
      "recorder": {
        "url": "https://recorder.maricopa.gov/recdocdata/",
        "search_method": "按 Recorded Name（业主/公司名）或 Document Number 搜索",
        "data_available": ["deed_of_trust", "liens", "lis_pendens", "assignments", "releases", "recording_date", "loan_amount"],
        "access": "FREE — 无需登录，公开查询",
        "jina_fallback": "https://r.jina.ai/https://recorder.maricopa.gov/recdocdata/",
